<Configuration>
  <Target name="My Computer">
    <EnableDebuggingForAllVIs>0</EnableDebuggingForAllVIs>
    <VI name="PCANBasic.lvlib:Get Attached Channels.vi">
      <Breakpoints>
        <NodeIndexes>
        </NodeIndexes>
        <SignalIndexes>
        </SignalIndexes>
      </Breakpoints>
      <Probes>
        <Generic>
          <SignalUID value="4079"/>
          <SignalUID value="5002"/>
        </Generic>
      </Probes>
    </VI>
    <VI name="PCANBasic.lvlib:Get PCAN API Version.vi">
      <Breakpoints>
        <NodeIndexes>
        </NodeIndexes>
        <SignalIndexes>
        </SignalIndexes>
      </Breakpoints>
      <Probes>
        <Generic>
          <SignalUID value="186"/>
        </Generic>
      </Probes>
    </VI>
    <VI name="PCANBasic.lvlib:Get PCAN API Version.vi:3350001">
      <Breakpoints>
        <NodeIndexes>
        </NodeIndexes>
        <SignalIndexes>
        </SignalIndexes>
      </Breakpoints>
      <Probes>
